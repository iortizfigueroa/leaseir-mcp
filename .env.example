# ======================================================================
#  MCP de Leaseir — configuración
#  Copia este fichero a  .env  y rellena los valores. NO subas .env a git.
# ======================================================================

# --- Servidor ---------------------------------------------------------
HOST=0.0.0.0
PORT=8000
# Token que protege el servidor. Invéntate uno largo y aleatorio.
# Cada cliente MCP deberá enviar:  Authorization: Bearer <este token>
# Genera uno con:  python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_AUTH_TOKEN=

# --- Airtable (base "Leaseir") ---------------------------------------
# Personal Access Token de Airtable: https://airtable.com/create/tokens
# Dale scope data.records:read y data.records:write sobre la base Leaseir.
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=app9U5sz7YS8y9Oit
AIRTABLE_TABLE_INMOVILIZADO=Inmovilizado
AIRTABLE_TABLE_PEDIDOS=Pedidos
# Valor de Status para pedidos creados desde el MCP (debe existir como opción
# en el campo Status). Por defecto el estado inicial del funnel.
AIRTABLE_DRAFT_STATUS=Pendiente de Aprobación

# --- Jira (SAT) -------------------------------------------------------
JIRA_BASE_URL=https://leaseir.atlassian.net
JIRA_EMAIL=tu-email@leaseir.com
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN=
# Clave del proyecto de SAT en Jira (mírala en la URL de un ticket: XXX-123)
JIRA_PROJECT_KEY=SAT
JIRA_ISSUE_TYPE=Task

# --- MongoDB Cloudmed (telemetría real de los equipos) ----------------
# Mismo Mongo Atlas que el portal Cloudmed. USUARIO READ-ONLY (cloudmed-read-api).
# Pon aquí la misma CLOUDMED_MONGO_URI que usa el portal en Vercel.
CLOUDMED_MONGO_URI=
CLOUDMED_DB=cloudmed
# Colección derivada de tramos (la "pulses new 2026"):
CLOUDMED_COLLECTION=pulses_handpiece_2026
CLOUDMED_MESSAGES_COLLECTION=messages
CLOUDMED_TZ=Europe/Madrid
